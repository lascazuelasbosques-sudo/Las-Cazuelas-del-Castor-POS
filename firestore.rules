rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: name (string), email (string), role (string), active (bool)
    //
    // Collection: categories
    // Fields: name (string), order (number)
    //
    // Collection: products
    // Fields: name (string), price (number), categoryId (string), stock (number), available (bool)
    //
    // Collection: orders
    // Fields: tableNumber (string), status (string), items (list), total (number), createdAt (timestamp), waiterId (string)
    //
    // Collection: cashLogs
    // Fields: type (string), amount (number), timestamp (timestamp), userId (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isEmailAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "lascazuelasbosques@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailAdmin() || (isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Staff can be identified by being authenticated (even anonymously)
    function isStaff() {
      return isAuthenticated();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'role']) &&
             data.name is string && data.name.size() < 100 &&
             data.role in ['admin', 'waiter', 'kitchen', 'cashier'];
    }

    match /users/{userId} {
      // allow get: users can see their own profile, admins can see everyone
      allow get: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // allow list: admins can list all. 
      // Staff (even anonymous) can search for a user document by username for login verification
      allow list: if isAdmin() || (isStaff() && resource.data.username != "");

      allow create: if isStaff() && isValidUser(request.resource.data) && (
        request.auth.uid == userId || isAdmin()
      );
      
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && (
        // Prevent changing your own role if not admin
        (isAdmin()) || (incoming().role == existing().role)
      );
      
      allow delete: if isAdmin() && userId != request.auth.uid; // Prevent self-deletion
    }

    match /test/connection {
      allow read: if true;
    }

    match /categories/{catId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /products/{prodId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /cashLogs/{logId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'cashier');
      allow delete: if isAdmin();
    }

    // Add transactions match just in case it's used as a collection
    match /transactions/{id} {
      allow read, write: if isAdmin();
    }

    match /counters/{counterId} {
      allow read, write: if isStaff();
    }
  }
}
